{
  "compilerOptions": {
    "composite": true,
    "target": "ES2021",
    "lib": ["ES2021"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "strict": true
  },
  "include": ["vite.config.ts", "src/types.ts", "src/data/**/*.ts", "src/lib/postcardPrompt.ts"]
}
